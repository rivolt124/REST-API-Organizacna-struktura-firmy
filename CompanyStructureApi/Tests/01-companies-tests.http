### ============================================================
### COMPANIES TESTS
### ============================================================

# @name GetAll
GET {{host}}/api/companies
Accept: application/json

###

# @name GetById
GET {{host}}/api/companies/{{testCompanyId}}
Accept: application/json

###

# @name GetByIdNotFound
GET {{host}}/api/companies/99999
Accept: application/json

###

# @name SearchByCode
GET {{host}}/api/companies/search?code=CORP-TEST-AUTO
Accept: application/json

###

# @name SearchByName
GET {{host}}/api/companies/search?name=TestCorp
Accept: application/json

###

# @name SearchHasDirector
GET {{host}}/api/companies/search?hasDirector=true
Accept: application/json

###

# @name SearchNoDirector
GET {{host}}/api/companies/search?hasDirector=false
Accept: application/json

###

# @name SearchNoMatch
GET {{host}}/api/companies/search?name=XXXXXXXXXXX
Accept: application/json

###

# @name PostBadRequest
POST {{host}}/api/companies
Content-Type: application/json

{
  "companyName": "Invalid Corp",
  "companyCode": "CORP-INVALID",
  "directorId": 1
}

###

# @name PostConflict
POST {{host}}/api/companies
Content-Type: application/json

{
  "companyName": "Duplicate Corp",
  "companyCode": "CORP-TEST-AUTO",
  "directorId": null
}

###

# @name PutUpdateName
PUT {{host}}/api/companies/{{testCompanyId}}
Content-Type: application/json

{
  "companyName": "TestCorp a.s.",
  "companyCode": "CORP-TEST-AUTO",
  "directorId": null
}

###

# @name PutAssignDirector
PUT {{host}}/api/companies/{{testCompanyId}}
Content-Type: application/json

{
  "companyName": "TestCorp a.s.",
  "companyCode": "CORP-TEST-AUTO",
  "directorId": {{testDirectorId}}
}

###

# @name PutRemoveDirector
PUT {{host}}/api/companies/{{testCompanyId}}
Content-Type: application/json

{
  "companyName": "TestCorp a.s.",
  "companyCode": "CORP-TEST-AUTO",
  "directorId": null
}

###

# @name PutRestore
PUT {{host}}/api/companies/{{testCompanyId}}
Content-Type: application/json

{
  "companyName": "TestCorp s.r.o.",
  "companyCode": "CORP-TEST-AUTO",
  "directorId": {{testDirectorId}}
}

###

# @name PutConflict
PUT {{host}}/api/companies/{{testCompanyId}}
Content-Type: application/json

{
  "companyName": "TestCorp s.r.o.",
  "companyCode": "CORP-OTHER-AUTO",
  "directorId": null
}

###

# @name PutBadDirector
PUT {{host}}/api/companies/{{testCompanyId}}
Content-Type: application/json

{
  "companyName": "TestCorp s.r.o.",
  "companyCode": "CORP-TEST-AUTO",
  "directorId": {{testOtherEmployeeId}}
}

###

# @name PutNotFound
PUT {{host}}/api/companies/99999
Content-Type: application/json

{
  "companyName": "Ghost Corp",
  "companyCode": "CORP-GHOST",
  "directorId": null
}

###

# @name PostMissingFields
POST {{host}}/api/companies
Content-Type: application/json

{}

###

# @name DeleteNotFound
DELETE {{host}}/api/companies/99999
Accept: application/json

###

# @name DeleteCompanyConflict
DELETE {{host}}/api/companies/{{testCompanyId}}
Accept: application/json